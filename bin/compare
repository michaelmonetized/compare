#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"

usage() {
  cat <<'EOF'
compare — git-isolated command benchmarker

Usage:
  compare <command-a> <command-b> [options]
  compare graph <log-file>
  compare report <log-file>

Options:
  -n, --number <N>   Run each command N times per branch (default: 1)
  -c, --cwd <path>   Working directory for both commands (default: .)
  -o, --output <path> Log file path (default: ../tests/compare-<cwd>-<c1>-<c2>-<endtime>.log)
  -g, --graph        Render terminal line charts after the benchmark
  --md               Write a markdown report (.md) and view it with mdr (or open)
  -h, --help         Show this help

Subcommands:
  compare graph <log-file>    Plot user, system, CPU, and total time from a log file
  compare report <log-file>   Regenerate the .md report from an existing log file

Examples:
  compare "echo a" "echo b"
  compare "npm test" "npm run test:fast" -n 10 -c ./app --graph
  compare "npm test" "npm run test:fast" -n 10 --md
  compare graph ./results/bench.log
EOF
}

log_to_md_path() {
  local log_file="$1"
  if [[ "$log_file" == *.log ]]; then
    printf '%s' "${log_file%.log}.md"
  else
    printf '%s.md' "$log_file"
  fi
}

show_markdown_report() {
  local md_file="$1"
  local abs_md
  abs_md="$(cd "$(dirname "$md_file")" && pwd)/$(basename "$md_file")"

  if command -v mdr >/dev/null 2>&1; then
    mdr "$abs_md"
    return
  fi

  echo "compare: mdr not found; falling back to system open" >&2
  echo "compare: tip: brew install CleverCloud/misc/mdr" >&2

  case "$(uname -s)" in
    Darwin)
      open "$abs_md"
      ;;
    Linux)
      if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$abs_md" >/dev/null 2>&1 &
      else
        echo "compare: error: install mdr or xdg-open; file is at $abs_md" >&2
        exit 1
      fi
      ;;
    *)
      echo "compare: error: install mdr; file is at $abs_md" >&2
      exit 1
      ;;
  esac
}

generate_markdown_report() {
  local log_file="$1"
  local md_file="$2"
  if [[ ! -f "$log_file" ]]; then
    echo "compare: error: log file not found: $log_file" >&2
    exit 1
  fi
  awk -v log_path="$log_file" -v md_path="$md_file" -f - "$log_file" <<'AWK' >"$md_file"
BEGIN {
  FS = "\n"
  RS = "\n\n+"
}
function min2(a, b) { return (a < b) ? a : b }
function max2(a, b) { return (a > b) ? a : b }
function mermaid_escape(s,    t) {
  gsub(/\\/, "\\\\", s)
  gsub(/"/, "'", s)
  return s
}
function short_label(s,    n) {
  n = length(s)
  if (n > 48) return substr(s, 1, 45) "..."
  return s
}
function format_median(val, unit,    fmt) {
  if (unit == "%") return sprintf("%.2f%%", val)
  return sprintf("%.3fs", val)
}
function chart_winner(ma, mb) {
  if (ma < mb) return "a"
  if (mb < ma) return "b"
  return "tie"
}
function parse_line(line,    parts, n, t, tn, u, s, tot) {
  n = split(line, parts, /  +/)
  if (n < 2) return 0
  cmd = parts[1]
  tn = split(parts[2], t, " ")
  if (tn < 8 || t[2] != "user" || t[4] != "system" || t[6] != "cpu" || t[8] != "total") return 0
  u = t[1]
  s = t[3]
  tot = t[7]
  sub(/s$/, "", u)
  sub(/s$/, "", s)
  sub(/%$/, "", t[5])
  u_val = u + 0
  s_val = s + 0
  c_val = t[5] + 0
  t_val = tot + 0
  return 1
}
function median(arr, n,    i, j, tmp, mid) {
  if (n == 0) return 0
  for (i = 1; i <= n; i++) sorted[i] = arr[i]
  for (i = 1; i <= n; i++) {
    for (j = i + 1; j <= n; j++) {
      if (sorted[j] < sorted[i]) {
        tmp = sorted[i]
        sorted[i] = sorted[j]
        sorted[j] = tmp
      }
    }
  }
  if (n % 2 == 1) return sorted[(n + 1) / 2]
  mid = n / 2
  return (sorted[mid] + sorted[mid + 1]) / 2
}
function series_min(arr, n,    i, v) {
  v = arr[1]
  for (i = 2; i <= n; i++) v = min2(v, arr[i])
  return v
}
function series_max(arr, n,    i, v) {
  v = arr[1]
  for (i = 2; i <= n; i++) v = max2(v, arr[i])
  return v
}
function metric_bounds(a, na, b, nb,    minv, maxv) {
  minv = 0
  maxv = 0.0001
  if (na > 0) {
    minv = min2(minv, series_min(a, na))
    maxv = max2(maxv, series_max(a, na))
  }
  if (nb > 0) {
    minv = min2(minv, series_min(b, nb))
    maxv = max2(maxv, series_max(b, nb))
  }
  if (maxv - minv < 0.00001) maxv = minv + 1
  else maxv = minv + (maxv - minv) * 1.15
  return minv " " maxv
}
function print_xychart(title, ylab, unit, a, na, b, nb,    minv, maxv, bounds, i, nmax, ma, mb, w, wname, wv, winner_note) {
  split(metric_bounds(a, na, b, nb), bounds, " ")
  minv = bounds[1] + 0
  maxv = bounds[2] + 0
  nmax = (na > nb) ? na : nb
  ma = median(a, na)
  mb = median(b, nb)
  w = chart_winner(ma, mb)
  if (w == "a") {
    wname = label_a
    wv = ma
    winner_note = sprintf("winner: %s (%s)", short_label(wname), format_median(wv, unit))
  } else if (w == "b") {
    wname = label_b
    wv = mb
    winner_note = sprintf("winner: %s (%s)", short_label(wname), format_median(wv, unit))
  } else {
    wname = "tie"
    wv = ma
    winner_note = sprintf("tie at %s", format_median(wv, unit))
  }

  print ""
  print "### " title
  print ""
  print "```mermaid"
  print "xychart-beta"
  printf "    title \"%s — %s\"\n", mermaid_escape(title), mermaid_escape(winner_note)
  printf "    x-axis ["
  for (i = 1; i <= nmax; i++) {
    if (i > 1) printf ", "
    printf "%d", i
  }
  print "]"
  if (ylab == "%") printf "    y-axis \"CPU %%\" %.2f --> %.2f\n", minv, maxv
  else printf "    y-axis \"%s\" %.4f --> %.4f\n", ylab, minv, maxv
  printf "    line \"%s\" [", mermaid_escape(short_label(label_a))
  for (i = 1; i <= na; i++) {
    if (i > 1) printf ", "
    printf "%s", a[i]
  }
  print "]"
  printf "    line \"%s\" [", mermaid_escape(short_label(label_b))
  for (i = 1; i <= nb; i++) {
    if (i > 1) printf ", "
    printf "%s", b[i]
  }
  print "]"
  print "```"
  print ""
  print "| Series | Command | Median |"
  print "|--------|---------|--------|"
  printf "| Line 1 | `%s` | %s |\n", label_a, format_median(ma, unit)
  printf "| Line 2 | `%s` | %s |\n", label_b, format_median(mb, unit)
  if (w == "tie") {
    printf "| **Result** | tie | %s |\n", format_median(ma, unit)
  } else {
    printf "| **Winner** | `%s` | **%s** |\n", wname, format_median(wv, unit)
  }
}
{
  block = $0
  n = split(block, lines, /\n/)
  delete u_series
  delete s_series
  delete c_series
  delete t_series
  count = 0
  for (i = 1; i <= n; i++) {
    line = lines[i]
    gsub(/^[ \t]+|[ \t]+$/, "", line)
    if (line == "") continue
    if (parse_line(line)) {
      count++
      u_series[count] = u_val
      s_series[count] = s_val
      c_series[count] = c_val
      t_series[count] = t_val
      if (count == 1) block_cmd = cmd
    }
  }
  if (count == 0) next
  if (block_num == 0) {
    for (i = 1; i <= count; i++) {
      a_user[i] = u_series[i]
      a_system[i] = s_series[i]
      a_cpu[i] = c_series[i]
      a_total[i] = t_series[i]
    }
    na = count
    label_a = block_cmd
  } else if (block_num == 1) {
    for (i = 1; i <= count; i++) {
      b_user[i] = u_series[i]
      b_system[i] = s_series[i]
      b_cpu[i] = c_series[i]
      b_total[i] = t_series[i]
    }
    nb = count
    label_b = block_cmd
  }
  block_num++
}
END {
  if (na == 0 && nb == 0) {
    print "compare: error: no timing lines found in log" > "/dev/stderr"
    exit 1
  }
  if (na == 0 || nb == 0) {
    print "compare: error: expected two command blocks separated by a blank line" > "/dev/stderr"
    exit 1
  }

  print "# Compare benchmark"
  print ""
  print "| | |"
  print "|---|---|"
  printf "| **Command A** | `%s` |\n", label_a
  printf "| **Command B** | `%s` |\n", label_b
  printf "| **Iterations** | %d vs %d |\n", na, nb
  printf "| **Log file** | `%s` |\n", log_path
  printf "| **Report** | `%s` |\n", md_path

  print ""
  print "## Results"
  print ""
  print "### Command A"
  print ""
  print "| Iteration | User (s) | System (s) | CPU (%) | Total (s) |"
  print "|-----------|----------|------------|---------|-----------|"
  for (i = 1; i <= na; i++) {
    printf "| %d | %.3f | %.3f | %.2f | %.3f |\n", i, a_user[i], a_system[i], a_cpu[i], a_total[i]
  }

  print ""
  print "### Command B"
  print ""
  print "| Iteration | User (s) | System (s) | CPU (%) | Total (s) |"
  print "|-----------|----------|------------|---------|-----------|"
  for (i = 1; i <= nb; i++) {
    printf "| %d | %.3f | %.3f | %.2f | %.3f |\n", i, b_user[i], b_system[i], b_cpu[i], b_total[i]
  }

  print ""
  print "## Summary (median)"
  print ""
  print "| Metric | Command A | Command B | Δ (B − A) |"
  print "|--------|-----------|-----------|-----------|"
  mu = median(a_user, na)
  mb = median(b_user, nb)
  printf "| User (s) | %.3f | %.3f | %+.3f |\n", mu, mb, mb - mu
  mu = median(a_system, na)
  mb = median(b_system, nb)
  printf "| System (s) | %.3f | %.3f | %+.3f |\n", mu, mb, mb - mu
  mu = median(a_cpu, na)
  mb = median(b_cpu, nb)
  printf "| CPU (%%) | %.2f | %.2f | %+.2f |\n", mu, mb, mb - mu
  mu = median(a_total, na)
  mb = median(b_total, nb)
  printf "| Total (s) | %.3f | %.3f | %+.3f |\n", mu, mb, mb - mu

  print ""
  print "## Charts"
  print ""
  total_a = median(a_total, na)
  total_b = median(b_total, nb)
  overall = chart_winner(total_a, total_b)
  if (overall == "a") {
    printf "**Overall winner (total time):** `%s` (%s vs %s)\n\n", label_a, format_median(total_a, "s"), format_median(total_b, "s")
  } else if (overall == "b") {
    printf "**Overall winner (total time):** `%s` (%s vs %s)\n\n", label_b, format_median(total_b, "s"), format_median(total_a, "s")
  } else {
    printf "**Overall winner (total time):** tie at %s\n\n", format_median(total_a, "s")
  }
  print "Lower median is better. Line 1 is the first command above; line 2 is the second."
  print ""
  print_xychart("User time", "seconds", "s", a_user, na, b_user, nb)
  print_xychart("System time", "seconds", "s", a_system, na, b_system, nb)
  print_xychart("CPU utilization", "%", "%", a_cpu, na, b_cpu, nb)
  print_xychart("Total time", "seconds", "s", a_total, na, b_total, nb)
}
AWK
}

graph_usage() {
  cat <<'EOF'
compare graph — terminal line charts from a compare log file

Usage:
  compare graph <log-file>

Plots four charts (user time, system time, CPU %, total time) with one line per command.
EOF
}

render_graphs() {
  local log_file="$1"
  if [[ ! -f "$log_file" ]]; then
    echo "compare: error: log file not found: $log_file" >&2
    exit 1
  fi
  awk -f - "$log_file" <<'AWK'
BEGIN {
  WIDTH = 48
  HEIGHT = 8
  FS = "\n"
  RS = "\n\n+"
}
function min2(a, b) { return (a < b) ? a : b }
function max2(a, b) { return (a > b) ? a : b }
function trunc_label(s,   n) {
  n = length(s)
  if (n > 42) return substr(s, 1, 39) "..."
  return s
}
function parse_line(line,    parts, n, t, tn, u, s, tot) {
  n = split(line, parts, /  +/)
  if (n < 2) return 0
  cmd = parts[1]
  tn = split(parts[2], t, " ")
  if (tn < 8 || t[2] != "user" || t[4] != "system" || t[6] != "cpu" || t[8] != "total") return 0
  u = t[1]
  s = t[3]
  tot = t[7]
  sub(/s$/, "", u)
  sub(/s$/, "", s)
  sub(/%$/, "", t[5])
  u_val = u + 0
  s_val = s + 0
  c_val = t[5] + 0
  t_val = tot + 0
  return 1
}
function series_min(arr, n,    i, v) {
  v = arr[1]
  for (i = 2; i <= n; i++) v = min2(v, arr[i])
  return v
}
function series_max(arr, n,    i, v) {
  v = arr[1]
  for (i = 2; i <= n; i++) v = max2(v, arr[i])
  return v
}
function plot_metric(title, unit, a, na, b, nb,    minv, maxv, span, row, col, x, i, grid, val, r, label, ytick, step) {
  if (na == 0 && nb == 0) return
  minv = 0
  maxv = 0.0001
  if (na > 0) {
    minv = min2(minv, series_min(a, na))
    maxv = max2(maxv, series_max(a, na))
  }
  if (nb > 0) {
    minv = min2(minv, series_min(b, nb))
    maxv = max2(maxv, series_max(b, nb))
  }
  span = maxv - minv
  if (span < 0.00001) span = maxv
  if (span < 0.00001) span = 1
  maxv = minv + span * 1.15

  printf "\n%s (%s)\n", title, unit
  delete grid
  for (row = 0; row < HEIGHT; row++) {
    for (col = 0; col < WIDTH; col++) grid[row, col] = " "
  }

  step = (na > 1) ? (WIDTH - 1) / (na - 1) : 0
  if (nb > na) step = (nb > 1) ? (WIDTH - 1) / (nb - 1) : 0
  nmax = (na > nb) ? na : nb
  if (nmax < 1) nmax = 1
  if (nmax == 1) step = 0

  for (i = 1; i <= na; i++) {
    col = int((i - 1) * step + 0.5)
    val = a[i]
    row = int((HEIGHT - 1) - (val - minv) / (maxv - minv) * (HEIGHT - 1) + 0.5)
    if (row < 0) row = 0
    if (row >= HEIGHT) row = HEIGHT - 1
    grid[row, col] = "A"
    if (i > 1) {
      prev_col = int((i - 2) * step + 0.5)
      prev_val = a[i - 1]
      prev_row = int((HEIGHT - 1) - (prev_val - minv) / (maxv - minv) * (HEIGHT - 1) + 0.5)
      draw_line(grid, prev_row, prev_col, row, col, "a")
    }
  }

  for (i = 1; i <= nb; i++) {
    col = int((i - 1) * step + 0.5)
    val = b[i]
    row = int((HEIGHT - 1) - (val - minv) / (maxv - minv) * (HEIGHT - 1) + 0.5)
    if (row < 0) row = 0
    if (row >= HEIGHT) row = HEIGHT - 1
    if (grid[row, col] == " " || grid[row, col] == "a" || grid[row, col] == "b") grid[row, col] = "B"
    if (i > 1) {
      prev_col = int((i - 2) * step + 0.5)
      prev_val = b[i - 1]
      prev_row = int((HEIGHT - 1) - (prev_val - minv) / (maxv - minv) * (HEIGHT - 1) + 0.5)
      draw_line(grid, prev_row, prev_col, row, col, "b")
    }
  }

  for (row = 0; row < HEIGHT; row++) {
    ytick = maxv - (maxv - minv) * row / (HEIGHT - 1)
    if (HEIGHT == 1) ytick = maxv
    if (unit == "%") printf "%6.1f |", ytick
    else printf "%6.3f |", ytick
    for (col = 0; col < WIDTH; col++) {
      ch = grid[row, col]
      if (ch == "A") printf "\033[34m*\033[0m"
      else if (ch == "B") printf "\033[33m*\033[0m"
      else if (ch == "a") printf "\033[34m-\033[0m"
      else if (ch == "b") printf "\033[33m-\033[0m"
      else printf " "
    }
    printf "\n"
  }
  printf "       +"
  for (col = 0; col < WIDTH; col++) printf "-"
  printf "\n"
  printf "        "
  for (i = 1; i <= nmax; i++) {
    col = int((i - 1) * step + 0.5)
    if (i == 1 || col != int((i - 2) * step + 0.5)) {
      label = sprintf("%d", i)
      printf "%s", label
      if (i < nmax) {
        next_col = int(i * step + 0.5)
        pad = next_col - col - length(label)
        if (pad < 1) pad = 1
        for (x = 0; x < pad; x++) printf " "
      }
    }
  }
  printf "  iteration\n"
  printf "        \033[34m*\033[0m %s    \033[33m*\033[0m %s\n", label_a, label_b
}
function draw_line(grid, r0, c0, r1, c1, kind,    steps, i, t, r, c, dr, dc, ch) {
  dr = r1 - r0
  dc = c1 - c0
  steps = max2(abs(dr), abs(dc))
  if (steps < 1) return
  ch = (kind == "a") ? "a" : "b"
  for (i = 0; i <= steps; i++) {
    t = i / steps
    r = int(r0 + dr * t + 0.5)
    c = int(c0 + dc * t + 0.5)
    if (r >= 0 && r < HEIGHT && c >= 0 && c < WIDTH) {
      if (grid[r, c] == " ") grid[r, c] = ch
    }
  }
}
function abs(x) { return (x < 0) ? -x : x }
{
  block = $0
  n = split(block, lines, /\n/)
  delete u_series
  delete s_series
  delete c_series
  delete t_series
  count = 0
  for (i = 1; i <= n; i++) {
    line = lines[i]
    gsub(/^[ \t]+|[ \t]+$/, "", line)
    if (line == "") continue
    if (parse_line(line)) {
      count++
      u_series[count] = u_val
      s_series[count] = s_val
      c_series[count] = c_val
      t_series[count] = t_val
      if (count == 1) block_cmd = cmd
    }
  }
  if (count == 0) next
  if (block_num == 0) {
    for (i = 1; i <= count; i++) {
      a_user[i] = u_series[i]
      a_system[i] = s_series[i]
      a_cpu[i] = c_series[i]
      a_total[i] = t_series[i]
    }
    na = count
    label_a = trunc_label(block_cmd)
  } else if (block_num == 1) {
    for (i = 1; i <= count; i++) {
      b_user[i] = u_series[i]
      b_system[i] = s_series[i]
      b_cpu[i] = c_series[i]
      b_total[i] = t_series[i]
    }
    nb = count
    label_b = trunc_label(block_cmd)
  }
  block_num++
}
END {
  if (na == 0 && nb == 0) {
    print "compare: error: no timing lines found in log" > "/dev/stderr"
    exit 1
  }
  if (na == 0 || nb == 0) {
    print "compare: error: expected two command blocks separated by a blank line" > "/dev/stderr"
    exit 1
  }
  printf "compare graphs — %d vs %d iterations\n", na, nb
  plot_metric("User time", "seconds", a_user, na, b_user, nb)
  plot_metric("System time", "seconds", a_system, na, b_system, nb)
  plot_metric("CPU", "%", a_cpu, na, b_cpu, nb)
  plot_metric("Total time", "seconds", a_total, na, b_total, nb)
}
AWK
}

graph_main() {
  if [[ $# -ne 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    graph_usage
    [[ $# -eq 0 ]] && exit 1
    exit 0
  fi
  render_graphs "$1"
}

report_main() {
  local log_file="$1"
  local md_file
  if [[ -z "$log_file" || "$log_file" == "-h" || "$log_file" == "--help" ]]; then
    echo "usage: compare report <log-file>" >&2
    exit 1
  fi
  md_file="$(log_to_md_path "$log_file")"
  generate_markdown_report "$log_file" "$md_file"
  echo "$md_file"
}

slugify() {
  local input="$1"
  local slug
  slug="$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g')"
  if [[ -z "$slug" ]]; then
    slug="cmd"
  fi
  printf '%s' "${slug:0:40}"
}

command_slug() {
  local cmd="$1"
  local trimmed
  trimmed="$(printf '%s' "$cmd" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
  trimmed="$(printf '%s' "$trimmed" | sed -E 's/[[:space:]]+--[a-zA-Z0-9-]+.*$//')"
  slugify "$trimmed"
}

require_git_repo() {
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "compare: error: not inside a git repository" >&2
    exit 1
  fi
}

run_timed() {
  local cmd="$1"
  local timing
  timing="$(
    TIMEFORMAT='%Us user %Ss system %P%% cpu %R total'
    { time eval "$cmd" >/dev/null 2>&1; } 2>&1
  )" || true
  printf '%s  %s\n' "$cmd" "$timing"
}

run_benchmark() {
  local cmd="$1"
  local iterations="$2"
  local log_file="$3"
  local i

  for ((i = 1; i <= iterations; i++)); do
    run_timed "$cmd" >>"$log_file"
  done
}

default_output_path() {
  local cwd_path="$1"
  local cmd_a="$2"
  local cmd_b="$3"
  local endtime="$4"
  local cwd_slug c1 c2 parent tests_dir

  cwd_slug="$(slugify "$(basename "$(cd "$cwd_path" && pwd)")")"
  c1="$(command_slug "$cmd_a")"
  c2="$(command_slug "$cmd_b")"
  parent="$(cd "$cwd_path/.." && pwd)"
  tests_dir="$parent/tests"
  mkdir -p "$tests_dir"
  printf '%s/compare-%s-%s-%s-%s.log' "$tests_dir" "$cwd_slug" "$c1" "$c2" "$endtime"
}

main() {
  local cmd_a=""
  local cmd_b=""
  local cwd="."
  local output=""
  local number=1
  local graph=0
  local md=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -g | --graph)
        graph=1
        shift
        ;;
      --md)
        md=1
        shift
        ;;
      -n | --number)
        [[ $# -ge 2 ]] || {
          echo "compare: error: $1 requires a value" >&2
          exit 1
        }
        number="$2"
        shift 2
        ;;
      -c | --cwd)
        [[ $# -ge 2 ]] || {
          echo "compare: error: $1 requires a value" >&2
          exit 1
        }
        cwd="$2"
        shift 2
        ;;
      -o | --output)
        [[ $# -ge 2 ]] || {
          echo "compare: error: $1 requires a value" >&2
          exit 1
        }
        output="$2"
        shift 2
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "compare: error: unknown option: $1" >&2
        exit 1
        ;;
      *)
        if [[ -z "$cmd_a" ]]; then
          cmd_a="$1"
        elif [[ -z "$cmd_b" ]]; then
          cmd_b="$1"
        else
          echo "compare: error: unexpected argument: $1" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$cmd_a" || -z "$cmd_b" ]]; then
    echo "compare: error: two commands are required" >&2
    usage >&2
    exit 1
  fi

  if ! [[ "$number" =~ ^[0-9]+$ ]] || [[ "$number" -lt 1 ]]; then
    echo "compare: error: --number must be a positive integer" >&2
    exit 1
  fi

  if [[ ! -d "$cwd" ]]; then
    echo "compare: error: cwd does not exist: $cwd" >&2
    exit 1
  fi

  require_git_repo

  local abs_cwd
  abs_cwd="$(cd "$cwd" && pwd)"

  local endtime log_file
  endtime="$(date -u +%Y%m%dT%H%M%SZ)"
  if [[ -n "$output" ]]; then
    log_file="$output"
    mkdir -p "$(dirname "$log_file")"
  else
    log_file="$(default_output_path "$abs_cwd" "$cmd_a" "$cmd_b" "$endtime")"
  fi

  local orig_branch snapshot_sha slug_a slug_b branch_a branch_b
  orig_branch="$(git rev-parse --abbrev-ref HEAD)"
  snapshot_sha="$(git rev-parse HEAD)"

  if [[ -n "$(git status --porcelain)" ]]; then
    git add -A
    git commit -m "compare: snapshot before benchmark" --no-verify >/dev/null
    snapshot_sha="$(git rev-parse HEAD)"
  fi

  slug_a="$(command_slug "$cmd_a")"
  slug_b="$(command_slug "$cmd_b")"
  branch_a="compare/$slug_a"
  branch_b="compare/$slug_b"

  : >"$log_file"

  git branch -f "$branch_a" "$snapshot_sha" >/dev/null 2>&1 || git branch "$branch_a" "$snapshot_sha" >/dev/null
  git checkout "$branch_a" >/dev/null

  (
    cd "$abs_cwd"
    run_benchmark "$cmd_a" "$number" "$log_file"
  )

  printf '\n' >>"$log_file"

  git checkout "$orig_branch" >/dev/null
  git branch -f "$branch_b" "$snapshot_sha" >/dev/null 2>&1 || git branch "$branch_b" "$snapshot_sha" >/dev/null
  git checkout "$branch_b" >/dev/null

  (
    cd "$abs_cwd"
    run_benchmark "$cmd_b" "$number" "$log_file"
  )

  git checkout "$orig_branch" >/dev/null

  echo "$log_file"
  if [[ "$md" -eq 1 ]]; then
    local md_file
    md_file="$(log_to_md_path "$log_file")"
    generate_markdown_report "$log_file" "$md_file"
    echo "$md_file"
    show_markdown_report "$md_file"
  elif [[ "$graph" -eq 1 ]]; then
    render_graphs "$log_file"
  fi
}

if [[ "${1:-}" == "graph" ]]; then
  shift
  graph_main "$@"
  exit $?
fi

if [[ "${1:-}" == "report" ]]; then
  shift
  report_main "${1:-}"
  exit $?
fi

main "$@"